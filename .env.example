# Copy to `.env` and adjust if needed.
# All values have sensible defaults — only override what you need.

# Timezone for the "Cost by hour of day" / "by day of week" panels.
# Use any tz name (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones).
TZ=Europe/Madrid

# Where Claude Code stores its transcripts on the host.
# Default works for Linux/macOS. On Windows (WSL) use the WSL home path.
CLAUDE_PROJECTS_DIR=${HOME}/.claude/projects

# Port to expose Grafana on. Change if 3000 is taken.
GRAFANA_PORT=3000

# How often the ingester rescans for new data, in seconds.
INTERVAL_SECONDS=300
