      },
      "targets": [
        {
          "rawQueryText": "WITH ordered AS (\n  SELECT ts_epoch, cost_usd, total_tokens,\n         LAG(ts_epoch) OVER (ORDER BY ts_epoch) AS prev_ts\n  FROM events\n), flagged AS (\n  SELECT ts_epoch, cost_usd, total_tokens,\n         CASE WHEN prev_ts IS NULL OR ts_epoch - prev_ts > 18000 THEN 1 ELSE 0 END AS new_block\n  FROM ordered\n), numbered AS (\n  SELECT ts_epoch, cost_usd, total_tokens,\n         SUM(new_block) OVER (ORDER BY ts_epoch) AS block_id\n  FROM flagged\n), active AS (\n  SELECT MIN(ts_epoch) AS block_start, MIN(ts_epoch) + 18000 AS block_end,\n         SUM(cost_usd) AS cost, SUM(total_tokens) AS tokens\n  FROM numbered\n  WHERE block_id = (SELECT MAX(block_id) FROM numbered)\n)\nSELECT CASE WHEN strftime('%s','now') < block_end THEN MIN(1.0, (CAST(strftime('%s','now') AS REAL) - block_start) / 18000.0) ELSE 0 END AS elapsed_pct FROM active",
