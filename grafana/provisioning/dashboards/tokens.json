  "panels": [
    {
      "id": 100,
      "type": "stat",
      "title": "5h block \u2014 cost",
      "description": "Cost spent in the active 5-hour block (Claude Code subscription billing window).",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "tokens-sqlite"
      },
      "targets": [
        {
          "rawQueryText": "WITH ordered AS (\n  SELECT ts_epoch, cost_usd, total_tokens,\n         LAG(ts_epoch) OVER (ORDER BY ts_epoch) AS prev_ts\n  FROM events\n), flagged AS (\n  SELECT ts_epoch, cost_usd, total_tokens,\n         CASE WHEN prev_ts IS NULL OR ts_epoch - prev_ts > 18000 THEN 1 ELSE 0 END AS new_block\n  FROM ordered\n), numbered AS (\n  SELECT ts_epoch, cost_usd, total_tokens,\n         SUM(new_block) OVER (ORDER BY ts_epoch) AS block_id\n  FROM flagged\n), active AS (\n  SELECT MIN(ts_epoch) AS block_start, MIN(ts_epoch) + 18000 AS block_end,\n         SUM(cost_usd) AS cost, SUM(total_tokens) AS tokens\n  FROM numbered\n  WHERE block_id = (SELECT MAX(block_id) FROM numbered)\n)\nSELECT CASE WHEN strftime('%s','now') < block_end THEN cost ELSE 0 END AS cost FROM active",
          "queryType": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
