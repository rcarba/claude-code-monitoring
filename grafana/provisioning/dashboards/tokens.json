{
  "title": "Claude Code — Token & Cost",
  "uid": "claude-tokens",
  "schemaVersion": 39,
  "version": 3,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-30d", "to": "now" },
  "refresh": "5m",
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
        "query": "SELECT DISTINCT project FROM events ORDER BY project",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": "all",
        "current": { "selected": false, "text": "All", "value": "$__all" }
      },
      {
        "name": "model",
        "label": "Model",
        "type": "query",
        "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
        "query": "SELECT DISTINCT model FROM events WHERE model != '' ORDER BY model",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": "all",
        "current": { "selected": false, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total cost (period)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT COALESCE(SUM(cost_usd),0) AS cost FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000",
        "queryType": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total tokens (period)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT COALESCE(SUM(total_tokens),0) AS tokens FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000",
        "queryType": "table",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sessions",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT COUNT(DISTINCT session_id) AS sessions FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000",
        "queryType": "table",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache hit ratio",
      "description": "cache_read / (cache_read + cache_creation). Higher is cheaper.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT CAST(SUM(cache_read) AS REAL) / NULLIF(SUM(cache_read + cache_5m + cache_1h), 0) AS ratio FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000",
        "queryType": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "decimals": 1, "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.9 }] } },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "area", "textMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cost over time, by project",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT (ts_epoch / 3600) * 3600 AS time, project, SUM(cost_usd) AS cost FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000 GROUP BY time, project ORDER BY time",
        "queryType": "time series",
        "refId": "A",
        "timeColumns": ["time"]
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Tokens over time, by type",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT (ts_epoch / 86400) * 86400 AS time, SUM(input_tokens) AS input, SUM(output_tokens) AS output, SUM(cache_5m + cache_1h) AS cache_create, SUM(cache_read) AS cache_read FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000 GROUP BY time ORDER BY time",
        "queryType": "time series",
        "refId": "A",
        "timeColumns": ["time"]
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 0 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Cost by hour-of-day (period)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT CAST(strftime('%H', datetime(ts_epoch, 'unixepoch', 'localtime')) AS INTEGER) AS hour, SUM(cost_usd) AS cost FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000 GROUP BY hour ORDER BY hour",
        "queryType": "table",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byName", "options": "cost" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] } ] },
      "options": { "orientation": "vertical", "xField": "hour", "showValue": "auto", "stacking": "none", "legend": { "showLegend": false } }
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Cost by project (period)",
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT project, SUM(cost_usd) AS cost FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000 GROUP BY project ORDER BY cost DESC",
        "queryType": "table",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "displayLabels": ["percent"] }
    },
    {
      "id": 9,
      "type": "piechart",
      "title": "Cost by model (period)",
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT model, SUM(cost_usd) AS cost FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000 AND model != '' GROUP BY model ORDER BY cost DESC",
        "queryType": "table",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "displayLabels": ["percent"] }
    },
    {
      "id": 10,
      "type": "barchart",
      "title": "Cost by day of week",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT CASE CAST(strftime('%w', datetime(ts_epoch, 'unixepoch', 'localtime')) AS INTEGER) WHEN 0 THEN '7-Sun' WHEN 1 THEN '1-Mon' WHEN 2 THEN '2-Tue' WHEN 3 THEN '3-Wed' WHEN 4 THEN '4-Thu' WHEN 5 THEN '5-Fri' WHEN 6 THEN '6-Sat' END AS dow, SUM(cost_usd) AS cost FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000 GROUP BY dow ORDER BY dow",
        "queryType": "table",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": {}, "overrides": [ { "matcher": { "id": "byName", "options": "cost" }, "properties": [ { "id": "unit", "value": "currencyUSD" } ] } ] },
      "options": { "orientation": "vertical", "xField": "dow", "showValue": "auto", "legend": { "showLegend": false } }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Top sessions by cost",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 31 },
      "datasource": { "type": "frser-sqlite-datasource", "uid": "tokens-sqlite" },
      "targets": [{
        "rawQueryText": "SELECT substr(session_id, 1, 8) AS session, project, MIN(datetime(ts_epoch, 'unixepoch', 'localtime')) AS started, COUNT(*) AS messages, SUM(input_tokens) AS input, SUM(output_tokens) AS output, SUM(cache_5m + cache_1h) AS cache_create, SUM(cache_read) AS cache_read, SUM(total_tokens) AS total_tokens, ROUND(SUM(cost_usd), 3) AS cost_usd FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000 GROUP BY session_id ORDER BY cost_usd DESC LIMIT 25",
        "queryType": "table",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "cost_usd" }, "properties": [ { "id": "unit", "value": "currencyUSD" }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } } ] },
          { "matcher": { "id": "byName", "options": "total_tokens" }, "properties": [ { "id": "unit", "value": "short" } ] }
        ]
      },
      "options": { "showHeader": true, "footer": { "show": true, "reducer": ["sum"], "fields": ["cost_usd", "total_tokens"] } }
    }
  ]
}
