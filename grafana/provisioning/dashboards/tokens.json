          "rawQueryText": "SELECT substr(session_id, 1, 8) AS session, project, MIN(datetime(ts_epoch, 'unixepoch', 'localtime')) AS started, COUNT(*) AS messages, SUM(input_tokens) AS input, SUM(output_tokens) AS output, SUM(cache_5m + cache_1h) AS cache_create, SUM(cache_read) AS cache_read, SUM(total_tokens) AS total_tokens, ROUND(SUM(cost_usd), 3) AS cost_usd FROM events WHERE ts_epoch BETWEEN $__from/1000 AND $__to/1000 GROUP BY session_id ORDER BY cost_usd DESC LIMIT 25",
